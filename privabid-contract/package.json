{
  "name": "privabid-contracts",
  "version": "1.0.0",
  "description": "PrivaBid — Multi-mode FHE auction platform on Fhenix",
  "private": true,
  "scripts": {
    "compile":      "hardhat compile",
    "test":         "hardhat test",
