    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "cofhe-hardhat-plugin": "^0.1.0",
    "dotenv": "^16.0.0",
    "hardhat": "^2.22.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "@types/chai": "^4.3.0"
  }
}
