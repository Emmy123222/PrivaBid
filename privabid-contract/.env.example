# Copy this to .env and fill in your values
# NEVER commit .env to git

# Your deployer wallet private key (without 0x prefix)
# Fund it at: https://faucet.triangleplatform.com/arbitrum/sepolia
PRIVATE_KEY=your_private_key_here

# RPC endpoints — get free ones at https://alchemy.com
ARB_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
ETH_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Block explorer API key for contract verification
ARBISCAN_API_KEY=your_arbiscan_api_key

# Set to "true" to print gas usage after tests
REPORT_GAS=false
