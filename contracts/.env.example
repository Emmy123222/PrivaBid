# PrivaBid — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ─── Deployer Private Key ────────────────────────────────────────────────────
# The wallet that will deploy the contract and act as auctioneer
# Fund it with testnet ETH before deploying:
#   Arbitrum Sepolia: https://faucet.triangleplatform.com/arbitrum/sepolia
#   Ethereum Sepolia: https://sepoliafaucet.com
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ─── RPC URLs ────────────────────────────────────────────────────────────────
# Get free RPC endpoints from Alchemy or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARB_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── Block Explorer API Keys (for contract verification) ─────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key

# ─── Optional ────────────────────────────────────────────────────────────────
# Set to "true" to print gas report after tests
REPORT_GAS=false
# CoinMarketCap key for USD gas cost estimates in gas report
COINMARKETCAP_API_KEY=
